    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "drizzle-kit": "^0.28.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  }
